.vscode/**
__pycache__/

tensorboard/*
checkpoint/*
best_model/*
result/*
dataset/*
PBCLA/__pycache__/**
REDEME.md
# 先取消忽略 result 目录本身
!result/

# 然后取消忽略 result 下的特定子目录
!result/pred/
!result/metric/
!result/pred/dbond_m/
!result/pred/dbond_s/
!result/pred/dbond_m/multi/
!result/pred/dbond_s/multi/
!result/metric/dbond_m/
!result/metric/dbond_s/
!result/metric/dbond_m/multi/
!result/metric/dbond_s/multi/

!best_model/
!best_model/dbond_m/
!best_model/dbond_s/
# 保留所有目录里的 .gitkeep 文件
!**/.gitkeep

cache/
# 保留 dataset 中的特定文件
!dataset/dataset.fbr.csv
!dataset/dbond_m.test.csv
!dataset/dbond_m.train.shuffle.csv
!dataset/dbond_s.test.csv
!dataset/dbond_s.train.shuffle.csv
#!dataset/说明.md
# 最后指定要保留的具体文件
!result/pred/dbond_m/multi/default.pred.csv
!result/pred/dbond_s/multi/default.pred.csv
!result/metric/dbond_s/multi/default_metric.csv
!result/metric/dbond_s/single/default_metric.csv
!result/metric/dbond_m/multi/default_metric.csv

# 虚拟环境与工具目录
.venv/
.claude/*
.kilo/

 # 其他忽略
*.pyc
*.pt
*.svg
*.png
CLAUDE.md
plans/*
nul
AGENTS.md
.zcode/*
*.drawio

# Feature-group progressive addition 消融实验产物
# 训练 checkpoint / 5 折产物 / 日志 / 图缓存（权重由 *.pt 覆盖，这里补非 .pt 的派生文件）
checkpoints/graph_transform/feature_group_ablation/
logs/graph_transform/feature_group_ablation/
tensorboard/graph_transform/feature_group_ablation/
result/pred/graph_transform/feature_group_ablation/
# 对比分析结果默认放 result/metric/.../feature_group_comparison/，CSV 通常希望保留，故不忽略
# 但生成的 PDF 图表由 *.pdf 规则决定（当前未忽略 *.pdf，如需忽略可显式加 result/metric/graph_transform/feature_group_comparison/*.pdf）
